{
  "name": "simple-metronome",
  "productName": "Simple Metronome",
  "version": "2.0.0",
  "private": true,
  "description": "A focused browser metronome with tap tempo and progressive practice modes.",
  "author": {
    "name": "Nick Lalo",
    "url": "https://github.com/NickLalo"
  },
  "homepage": "https://nicklalo.github.io/simple-metronome/",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --open",
    "desktop:start": "npm run build && electron .",
    "desktop:package": "npm run build && electron-forge package",
    "desktop:make": "npm run build && electron-forge make",
    "lint": "eslint .",
    "test": "node --test",
    "check": "npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron/fuses": "^2.1.3",
    "electron": "^43.1.1",
    "eslint": "^10.7.0",
    "tone": "^15.1.22",
    "vite": "^8.1.4"
  },
  "allowScripts": {
    "electron-winstaller@5.4.4": true
  }
}
